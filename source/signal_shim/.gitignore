# ------------------------------------------------------------------------------
# Cargo/Rust Build Artifacts
# ------------------------------------------------------------------------------
# The target directory contains all compiled binaries, object files, and downloaded crates.
/target/

# Backup files generated by rustfmt
**/*.rs.bk

# ------------------------------------------------------------------------------
# Windows MSVC Specifics
# ------------------------------------------------------------------------------
# When compiling a cdylib on Windows, the MSVC linker sometimes drops these 
# alongside the DLL or inside intermediate folders.
*.pdb
*.lib
*.exp
*.ilk

# ------------------------------------------------------------------------------
# Dependency Locks (The Cargo.lock Debate)
# ------------------------------------------------------------------------------
# For pure Rust libraries published to crates.io, Cargo.lock is traditionally ignored.
# HOWEVER: Because this is an internal FFI shim tied directly to your .NET app's 
# build pipeline, you actually WANT reproducible builds. 
# 
# Recommendation: DO NOT ignore Cargo.lock. Let it be committed to source control 
# so your C# app always builds against the exact same underlying Rust crate versions.
# Cargo.lock

# ------------------------------------------------------------------------------
# OS / IDE generated files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/